# Copy to .env and adjust.
PORT=4000
NODE_ENV=development

# PostgreSQL
PGHOST=localhost
PGPORT=5432
PGDATABASE=sky_root_crm
PGUSER=postgres
PGPASSWORD=
# Or a single connection string (takes precedence if set):
# DATABASE_URL=postgres://postgres@localhost:5432/sky_root_crm

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES=7d

# Frontend origin for CORS
CLIENT_ORIGIN=http://localhost:5173
