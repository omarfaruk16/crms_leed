{
  "name": "sky-root-crm-server",
  "version": "1.0.0",
  "description": "Sky Root Properties CRM — Express + PostgreSQL API",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "db:init": "node src/db/init.js",
    "db:seed": "node src/db/seed.js",
    "db:reset": "node src/db/init.js && node src/db/seed.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.2.0",
    "pg": "^8.12.0"
  }
}
